  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
  <!-- Generate WSLDVCPlugin.rc from WSLDVCPlugin.rc.in before ResourceCompile
       runs. The .rc file is intentionally not checked in: it carries the
       FileVersion / InformationalVersion strings derived from `git describe`
       and the current commit SHA, which are computed at build time.

       Incremental rebuild semantics: MSBuild skips this target when the
       generated .rc is newer than every input (the .in template, the
       generator script, and the shared PowerShell helper). The CI pipeline
       still invokes UpdateRCVersion.ps1 explicitly with the queue-time
       separator before MSBuild runs, so this target sees the .rc as already
       up-to-date and does not re-run (which would otherwise overwrite the
       CI-correct separator with the local-dev default "-Beta"). -->
  <Target Name="GenerateWslDvcPluginRc"
          BeforeTargets="ResourceCompile"
          Inputs="$(MSBuildThisFileDirectory)WSLDVCPlugin.rc.in;$(MSBuildThisFileDirectory)UpdateRCVersion.ps1;$(MSBuildThisFileDirectory)..\devops\version_functions.ps1"
          Outputs="$(MSBuildThisFileDirectory)WSLDVCPlugin.rc">
    <Message Importance="high" Text="Generating WSLDVCPlugin.rc (WslgVersionSeparator=$(WslgVersionSeparator))" />
    <Exec Command="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)UpdateRCVersion.ps1&quot; -separator &quot;$(WslgVersionSeparator)&quot;"
          WorkingDirectory="$(MSBuildThisFileDirectory)" />
  </Target>
  <Target Name="CleanGeneratedWslDvcPluginRc" BeforeTargets="Clean">
    <Delete Files="$(MSBuildThisFileDirectory)WSLDVCPlugin.rc" />
  </Target>
